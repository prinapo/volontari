{
  "name": "volontari",
  "version": "3.6.0",
  "description": "Portale Volontario — Quasar frontend for Directus backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "preview": "quasar build && npx serve dist/spa",
    "lint": "eslint src --ext .js,.vue",
    "lint:css": "stylelint \"src/**/*.scss\"",
    "lint:a11y": "eslint src --ext .vue --rulesdir-esm 2>/dev/null; eslint src --ext .vue --rule 'vuejs-accessibility/*: error'",
    "lint:spell": "cspell --no-progress \"src/**/*.{js,vue}\"",
    "lint:md": "markdownlint \"*.md\" \".github/**/*.md\"",
    "lint:all": "npm run lint && npm run lint:css && npm run lint:a11y && npm run lint:md",
    "format": "prettier --write \"src/**/*.{js,vue,css,json}\"",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix --audit-level=high",
    "knip": "knip",
    "analyze": "quasar build",
    "test:unit": "vitest run --config tests/unit/vitest.config.mjs",
    "test:unit:ui": "vitest --config tests/unit/vitest.config.mjs --ui",
    "test:unit:coverage": "vitest run --config tests/unit/vitest.config.mjs --coverage",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:ui": "npx playwright test --config tests/e2e/playwright.config.js --ui",
    "deploy": "node scripts/deploy-ftp.mjs",
    "deploy:init": "node scripts/deploy-init.mjs",
    "rollback": "node scripts/rollback.mjs",
    "release": "quasar build && node scripts/deploy-ftp.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ],
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "knip": {
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "entry": [
      "src/index.template.html",
      "src/App.vue",
      "src/router/index.js",
      "src/stores/index.js",
      "src/boot/*.js",
      "src-pwa/*.js",
      "scripts/*.mjs",
      "quasar.config.cjs"
    ],
    "project": [
      "src/**/*.{js,vue,scss}",
      "src-pwa/**/*.js"
    ],
    "ignoreDependencies": [
      "@quasar/app-vite",
      "@vitejs/plugin-vue",
      "imapflow",
      "jscpd",
      "mailparser",
      "vite",
      "workbox-build",
      "workbox-cacheable-response",
      "workbox-core",
      "workbox-expiration",
      "workbox-precaching",
      "workbox-routing",
      "workbox-strategies"
    ],
    "ignore": [
      "tests/",
      "docs/"
    ],
    "vue": true,
    "ignoreBinaries": [
      "quasar",
      "serve"
    ]
  },
  "dependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@quasar/extras": "^1.16.0",
    "@vue/devtools-api": "^8.1.5",
    "axios": "^1.6.0",
    "eslint-plugin-import-x": "^4.17.1",
    "quasar": "^2.14.0",
    "register-service-worker": "^1.7.2",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "^1.61.1",
    "@quasar/app-vite": "^2.6.2",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "basic-ftp": "^6.0.1",
    "cspell": "^10.0.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-unicorn": "^56.0.1",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "husky": "^9.1.7",
    "imapflow": "^1.4.7",
    "jscpd": "^5.0.12",
    "jsdom": "^24.1.3",
    "knip": "^5.88.1",
    "lint-staged": "^17.0.8",
    "mailparser": "^3.9.14",
    "markdownlint-cli": "^0.49.0",
    "pinia": "^4.0.2",
    "prettier": "^3.8.4",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "vitest": "^4.1.10",
    "workbox-build": "^7.4.1",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  }
}
